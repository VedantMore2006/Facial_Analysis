# ------------------------------
# OS / Editor cruft
# ------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ------------------------------
# Python bytecode / caches
# ------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.ipynb_checkpoints/

# ------------------------------
# Virtual environments
# ------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------
# Packaging / build artifacts
# ------------------------------
build/
dist/
site/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ------------------------------
# Test / coverage artifacts
# ------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# ------------------------------
# Logs / runtime artifacts
# ------------------------------
*.log
logs/
*.pid
*.out
*.err

# ------------------------------
# Env / secrets
# ------------------------------
.env
.env.*
*.env
*.local
secrets.*

# ------------------------------
# Jupyter
# ------------------------------
*.ipynb_checkpoints

# ------------------------------
# Streamlit / app state
# ------------------------------
.streamlit/secrets.toml

# ------------------------------
# Project generated outputs
# ------------------------------
# Session exports, feature CSVs, temporary captures
data/**/*.csv
data/**/*.json
data/**/*.parquet
data/**/*.feather
data/**/*.pkl
data/**/*.npy
data/**/*.npz

# Validation and plots generated at runtime
plots/**
validation/**/*.png
validation/**/*.jpg
validation/**/*.jpeg
validation/**/*.svg
validation/**/*.pdf

# Temporary media artifacts
*.mp4
*.avi
*.mov
*.mkv
*.wav
*.tmp

# Model / large artifacts
models/
checkpoints/
artifacts/

# ------------------------------
# Optional: keep directory placeholders
# ------------------------------
!data/.gitkeep
!plots/.gitkeep
